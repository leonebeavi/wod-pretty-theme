{{!-- WoD Pretty Theme — custom BLOOD tab (Glass Gótico).
      Re-arranges the system's blood part into the Obsidian layout:
        Row 1 = Blood Potency dots + Humanity (system partial), two glass panels.
        Row 2 = six read-only blood-potency derived stats as cards.
        Row 3 = editable blood fields (sire/generation inputs, predator + resonance
                items, clan bane prosemirror display).
      Reuses the system's exact interactive markup (dot widget data-actions,
      remorseRoll, rollItem feeding roll, searchItem/createItem/itemEdit/itemDelete,
      {{{enrichedBane}}}) so all functionality is preserved.
      Context from prepareBloodContext: blood, bloodpotency, sire, generation,
      predator, resonance, enrichedBane, tab. --}}
<section class="tab {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
    <div class="gg-stack">

        {{!-- ROW 1: Blood Potency + Humanity --}}
        <div class="gg-grid-2">
            <div class="gg-panel gg-blood-center">
                <div class="gg-section-title">{{localize "WOD5E.VTM.BloodPotency"}}</div>
                <div class="resource-content flexrow flex-center">
                    <div class="resource-value" data-value="{{blood.potency}}" data-name="system.blood.potency">
                        <span class="resource-value-empty" data-action="dotCounterEmpty"></span>
                        {{#numLoop 10}}
                        <span class="resource-value-step" data-action="dotCounterChange" data-index="{{this}}"></span>
                        {{/numLoop}}
                    </div>
                </div>
            </div>
            <div class="gg-panel gg-blood-center">
                <div class="system-rollable remorse-roll" data-action="remorseRoll" title="{{localize 'WOD5E.VTM.RollRemorse'}}">
                    <div class="gg-section-title">{{localize "WOD5E.VTM.Humanity"}} <i class="fa-solid fa-dice-d10"></i></div>
                </div>
                {{> "systems/wod5e/display/vtm/actors/parts/humanity.hbs"}}
            </div>
        </div>

        {{!-- ROW 2: read-only blood-potency derived stats --}}
        <div class="gg-grid-3">
            <div class="gg-card">
                <div class="gg-field-label">{{localize "WOD5E.VTM.BloodSurge"}}</div>
                <div class="gg-kv-value">{{bloodpotency.surge}}</div>
            </div>
            <div class="gg-card">
                <div class="gg-field-label">{{localize "WOD5E.VTM.MendAmount"}}</div>
                <div class="gg-kv-value">{{bloodpotency.mend}}</div>
            </div>
            <div class="gg-card">
                <div class="gg-field-label">{{localize "WOD5E.VTM.PowerBonus"}}</div>
                <div class="gg-kv-value">{{bloodpotency.power}}</div>
            </div>
            <div class="gg-card">
                <div class="gg-field-label">{{localize "WOD5E.VTM.RouseReRoll"}}</div>
                <div class="gg-kv-value">{{bloodpotency.rouse}}</div>
            </div>
            <div class="gg-card">
                <div class="gg-field-label">{{localize "WOD5E.VTM.FeedingPenalty"}}</div>
                <div class="gg-kv-value">{{bloodpotency.feeding}}</div>
            </div>
            <div class="gg-card">
                <div class="gg-field-label">{{localize "WOD5E.VTM.BaneSeverity"}}</div>
                <div class="gg-kv-value">{{bloodpotency.bane}}</div>
            </div>
        </div>

        {{!-- ROW 3: editable blood fields --}}
        <div class="gg-grid-3">
            <div class="gg-card">
                <label class="gg-field-label" for="system.headers.sire">{{localize 'WOD5E.VTM.Sire'}}</label>
                <input class="resource" type="text" name="system.headers.sire" value="{{sire}}" placeholder="{{localize 'WOD5E.VTM.Sire'}}"/>
            </div>
            <div class="gg-card">
                {{#if predator.system.dicepool}}
                    <div class="system-rollable feeding-roll" data-action="rollItem" data-item-uuid="{{predator.uuid}}" title="{{localize 'WOD5E.VTM.FeedingRoll'}}">
                        <label class="gg-field-label">{{localize 'WOD5E.VTM.PredatorType'}} <i class="fa-solid fa-dice-d10"></i></label>
                    </div>
                {{else}}
                    <label class="gg-field-label">{{localize 'WOD5E.VTM.PredatorType'}}</label>
                {{/if}}
                <div class="resource resource-content gg-data-item-row">
                    {{#if predator}}
                        <span class="data-item">{{predator.name}}</span>
                        <a class="edit-data-item" data-action="itemEdit" data-item-id="{{predator.id}}">
                            <i class="fa-solid fa-pen-nib"></i>
                        </a>
                    {{else}}
                        <a class="search-data-item" data-action="searchItem" title="{{localize 'WOD5E.Search'}}" data-type="predatorType">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </a>
                        <a class="add-data-item" data-action="createItem" title="{{localize 'WOD5E.Add'}}" data-type="predatorType">
                            <i class="fa-solid fa-plus"></i>
                        </a>
                    {{/if}}
                </div>
            </div>
            <div class="gg-card">
                <label class="gg-field-label">{{localize 'WOD5E.VTM.BloodResonance'}}</label>
                <div class="resource resource-content gg-data-item-row">
                    {{#if resonance}}
                        <span class="data-item">{{resonance.name}}</span>
                        <a class="edit-data-item" data-action="itemEdit" data-item-id="{{resonance.id}}">
                            <i class="fa-solid fa-pen-nib"></i>
                        </a>
                        <a class="remove-data-item" data-action="itemDelete" data-item-id="{{resonance.id}}">
                            <i class="fa-solid fa-xmark"></i>
                        </a>
                    {{else}}
                        <a class="search-data-item" data-action="searchItem" title="{{localize 'WOD5E.Search'}}" data-type="resonance">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </a>
                        <a class="add-data-item" data-action="createItem" title="{{localize 'WOD5E.Add'}}" data-type="resonance">
                            <i class="fa-solid fa-plus"></i>
                        </a>
                    {{/if}}
                </div>
            </div>
            <div class="gg-card gg-bane-card">
                <label class="gg-field-label">{{localize "WOD5E.VTM.ClanBane"}} <span class="gg-readonly-tag">read-only</span></label>
                <div class="resource-contents prosemirror-resource resource bane">
                    <div>
                        {{{enrichedBane}}}
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
