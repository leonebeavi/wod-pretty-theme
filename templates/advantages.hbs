{{!-- WoD Pretty Theme — MERIT & FLAWS tab (Glass Gótico).
      The character's features in a 2×2 grid (CSS orders them Merit | Flaw /
      Background | Boon). Each row is a single line: image · name · horizontal
      dots · controls. Reuses the system's exact data-actions (search/create,
      dot counters, itemChat/Edit/Delete, drag) so all functionality is kept.
      Context from prepareFeaturesContext: features (+ top-level locked). --}}
<section class="tab {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
    <div class="gg-advantages">
        <div class="gg-panel">
            <div class="gg-title-left">{{localize "WPT.Tabs.Advantages"}}</div>
            <div class="gg-adv-grid features-list item-list">
                {{#each features as |feature key|}}
                    <div class="category gg-feature-col" data-category="{{key}}">
                        <div class="gg-col-head">
                            <span class="gg-cat-name">{{localize (generateLocalizedLabel key 'features')}}</span>
                            <span class="gg-col-controls">
                                <a class="item-control search-data-item" data-action="searchItem" title="{{localize 'WOD5E.Search'}}" data-type="feature" data-subtype="{{key}}">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </a>
                                <a class="item-control item-create" data-action="createItem" title="{{localize 'WOD5E.Add'}}" data-type="feature" data-subtype="{{key}}">
                                    <i class="fas fa-plus"></i>
                                </a>
                            </span>
                        </div>
                        {{#each feature as |item key|}}
                            <div class="collapsible-container gg-feature-row">
                                <div class="item" data-drag="true" data-item-id="{{item.id}}" data-document-uuid="{{item.uuid}}" data-type="Item">
                                    <div class="item-image">
                                        <img src="{{item.img}}" class="clickable" data-action="itemChat" data-item-id="{{item._id}}" title="{{localize 'WOD5E.ItemsList.ShowToChat'}}">
                                    </div>
                                    <div class="item-name{{#if item.system.enrichedDescription}} collapsible{{/if}}" {{#if item.system.enrichedDescription}}data-action="toggleCollapse"{{/if}}>
                                        {{item.name}}
                                    </div>
                                    {{#ifnoteq item.system.featuretype 'boon'}}
                                        <div class="dot-tracker">
                                            <div class="resource-value" data-value="{{item.system.points}}" data-name="items.{{item._id}}">
                                                <span class="resource-value-empty" data-action="dotCounterEmpty"></span>
                                                {{#numLoop 5}}
                                                    <span class="resource-value-step" data-action="dotCounterChange" data-index="{{this}}"></span>
                                                {{/numLoop}}
                                            </div>
                                        </div>
                                    {{/ifnoteq}}
                                    <div class="item-controls">
                                        <a class="item-control item-edit" data-action="itemEdit" data-item-id="{{item._id}}" title="{{localize 'WOD5E.Edit'}}">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a class="item-control item-delete" data-action="itemDelete" data-item-id="{{item._id}}" title="{{localize 'WOD5E.Delete'}}">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </div>
                                <div class="collapsible-content item-description">
                                    {{{item.system.enrichedDescription}}}
                                </div>
                            </div>
                        {{/each}}
                    </div>
                {{/each}}
            </div>
        </div>
    </div>
</section>
