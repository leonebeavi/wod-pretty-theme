{{!-- WoD Pretty Theme — custom VAMPIRE header (Glass Gótico).
      Three columns: vitals (health/willpower) · identity (portrait, name,
      "VAMPIRE · CLAN · GENERATION" subtitle) · status (clan, generation,
      hunger, Resist Frenzy pill).
      Reuses the system's own partials and data-actions so every control stays
      functional (edit image, name, health/willpower counters, clan add/edit,
      hunger dots, rouse, resist/end frenzy). The only added datum is
      `generation` (system.headers.generation), set in _preparePartContext. --}}
<header class="actor-header gg-header"{{#if headerbg}} style="background: url({{headerbg}}) center;"{{/if}}>

    {{!-- LEFT: vitals --}}
    <div class="gg-header-vitals">
        {{> "systems/wod5e/display/shared/actors/parts/health.hbs"}}
        {{> "systems/wod5e/display/shared/actors/parts/willpower.hbs"}}
    </div>

    {{!-- CENTER: portrait + identity --}}
    <div class="gg-header-identity">
        <div class="header-profile-img">
            <img class="profile-img" data-action="editImage" src="{{img}}" data-edit="img" title="{{actor.name}}"/>
        </div>
        <div class="flexrow name-field{{#if locked}} clickthrough{{/if}}">
            {{#if locked}}
                <div class="charname">{{name}}</div>
            {{else}}
                <input class="charname" name="name" type="text" value="{{name}}" placeholder="{{localize 'WOD5E.Name'}}"/>
            {{/if}}
        </div>
        <div class="gg-header-subtitle">
            <span class="gg-sub-splat">{{localize currentTypeLabel}}</span>
            {{#if clan}}<span class="gg-sub-sep">·</span><span class="gg-sub-clan">{{clan.name}}</span>{{/if}}
            {{#if generation}}<span class="gg-sub-sep">·</span><span class="gg-sub-gen">{{generation}}</span>{{/if}}
        </div>
    </div>

    {{!-- RIGHT: clan / generation / hunger / frenzy --}}
    <div class="gg-header-status">
        <div class="gg-status-fields">
            <div class="flexcol shared-row gg-field">
                <label class="resource-label field-header">{{localize 'WOD5E.VTM.Clan'}}</label>
                <div class="resource resource-content">
                    {{#if clan}}
                        <span class="data-item nowrap">{{clan.name}}</span>
                        <a class="edit-data-item" data-action="itemEdit" data-item-id="{{clan.id}}" title="{{localize 'WOD5E.Edit'}}"><i class="fa-solid fa-pen-nib"></i></a>
                    {{else}}
                        <a class="search-data-item" data-action="searchItem" title="{{localize 'WOD5E.Search'}}" data-type="clan"><i class="fa-solid fa-magnifying-glass"></i></a>
                        <a class="add-data-item" data-action="createItem" title="{{localize 'WOD5E.Add'}}" data-type="clan"><i class="fa-solid fa-plus"></i></a>
                    {{/if}}
                </div>
            </div>
            <div class="flexcol shared-row gg-field">
                <label class="resource-label field-header">{{localize 'WOD5E.VTM.Generation'}}</label>
                <div class="resource resource-content">
                    {{#if locked}}
                        <span class="data-item nowrap">{{#if generation}}{{generation}}{{else}}—{{/if}}</span>
                    {{else}}
                        <input class="resource gg-gen-input" type="text" name="system.headers.generation" value="{{generation}}" placeholder="—"/>
                    {{/if}}
                </div>
            </div>
        </div>

        <div class="flexcol field-section gg-hunger-block">
            <label class="resource-label field-header">{{localize "WOD5E.VTM.Hunger"}}</label>
            <div class="flexrow gg-hunger-row">
                {{> "systems/wod5e/display/vtm/actors/parts/hunger.hbs"}}
                {{> "systems/wod5e/display/vtm/actors/parts/rouse.hbs"}}
            </div>
        </div>

        <div class="gg-frenzy-wrap">
            {{> "systems/wod5e/display/vtm/actors/parts/frenzy.hbs"}}
        </div>
    </div>
</header>
